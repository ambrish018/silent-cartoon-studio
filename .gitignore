node_modules/
out/
jobs/
CLAUDE.md
__pycache__/
.env
.env.local

# Override a global ~/.gitignore_global "*.ts" rule that would otherwise silently
# drop TypeScript source (this is how src/characters/emotions.ts got lost before).
!*.ts
!src/**/*.ts

# macOS AppleDouble / metadata — kept AFTER the !*.ts negation so ._*.ts stays ignored
._*
.DS_Store

# Markdown — ignore new .md (already-tracked docs/README stay tracked)
*.md

# Generated media (renders, voiceover, frames). Source assets in assets/ are kept.
*.mp4
*.mp3
*.wav
*.aac
*.m4a
*.mov
*.png
*.jpg
*.jpeg
*.gif
!assets/**
